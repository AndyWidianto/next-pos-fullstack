// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  kasir
  user
}
model User {
  id       String @id @default(ulid())
  name     String?
  username String @unique
  email    String @unique
  password String
  role     UserRole @default(user)

  transactions Transaction[]
  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id      String  @id @default(ulid())
  name    String
  description String?
  icon    String

  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductUnit {
  PCS
  PACK
  BOX
  KG
  GR
  LITER
  MTR
}

model Product {
  id      String  @id @default(ulid())
  name    String
  sku     String
  code    String  @default("")
  price   Decimal @db.Decimal(12, 2)
  stock   Int
  init    ProductUnit @default(PCS)

  categoryId String
  
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  transactionsItems TransactionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Transaction {
  id             String            @id @default(uuid())
  invoiceNumber  String            @unique @map("invoice_number")
  totalPrice     Decimal           @db.Decimal(12, 2) @map("total_price")
  tax            Decimal           @default(0) @db.Decimal(12, 2)
  discount       Decimal           @default(0) @db.Decimal(12, 2)
  paymentMethod  String            @map("payment_method")
  userId         String            @map("user_id")
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relasi ke TransactionItems (One-to-Many)
  items          TransactionItem[]
  
  createdAt      DateTime          @default(now())

  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  productId     String      @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  
  quantity      Int
  priceAtTime   Decimal     @db.Decimal(12, 2) @map("price_at_time")

  @@map("transaction_items")
}
